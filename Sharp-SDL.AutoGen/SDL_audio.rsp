--file
SDL3-3.4.2\include\SDL3\SDL_audio.h

--libraryPath
SDL3

--include-directory
SDL3-3.4.2\include\ 

--output
../Sharp-SDL/SDLAudio.cs

--namespace 
Sharp_SDL

--methodClassName
SDLAudio

--config
compatible-codegen          
single-file
implicit-vtbls
generate-macro-bindings

--with-type
SDL_AudioFormat=uint

--exclude
SDL_DEFINE_AUDIO_FORMAT
SDL_AUDIO_BITSIZE
SDL_AUDIO_BYTESIZE
SDL_AUDIO_ISFLOAT
SDL_AUDIO_ISBIGENDIAN
SDL_AUDIO_ISLITTLEENDIAN
SDL_AUDIO_ISSIGNED
SDL_AUDIO_ISINT
SDL_AUDIO_ISUNSIGNED
SDL_AUDIO_FRAMESIZE