--file
SDL3-3.4.2\include\SDL3\SDL_iostream.h

--libraryPath
SDL3

--include-directory
SDL3-3.4.2\include\ 

--output
../Sharp-SDL/SDLIoStream.cs

--namespace 
Sharp_SDL

--methodClassName
SDLIoStream

--config
compatible-codegen          
single-file
