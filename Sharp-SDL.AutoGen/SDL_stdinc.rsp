--file
SDL3-3.4.2\include\SDL3\SDL_stdinc.h

--libraryPath
SDL3

--include-directory
SDL3-3.4.2\include\ 

--output
../Sharp-SDL/SDLStdInc.cs

--namespace 
Sharp_SDL

--methodClassName
SDLStdInc

--config
compatible-codegen          
single-file
implicit-vtbls
generate-macro-bindings

--exclude
SDL_size_mul_check_overflow_builtin
SDL_size_mul_check_overflow
SDL_size_add_check_overflow_builtin
SDL_IOvprintf
SDL_calloc
SDL_realloc
SDL_vsscanf
SDL_vsnprintf
SDL_vasprintf
SDL_COMPILE_TIME_ASSERT
SDL_arraysize
SDL_STRINGIFY_ARG
SDL_reinterpret_cast
SDL_static_cast
SDL_const_cast
SDL_FOURCC
SDL_SINT64_C
SDL_UINT64_C
SDL_IN_BYTECAP
SDL_INOUT_Z_CAP
SDL_OUT_Z_CAP
SDL_OUT_CAP
SDL_OUT_BYTECAP
SDL_OUT_Z_BYTECAP
SDL_PRINTF_VARARG_FUNC
SDL_PRINTF_VARARG_FUNCV
SDL_SCANF_VARARG_FUNC
SDL_SCANF_VARARG_FUNCV
SDL_WPRINTF_VARARG_FUNC
SDL_WPRINTF_VARARG_FUNCV
SDL_INIT_INTERFACE
SDL_stack_alloc
SDL_stack_free
SDL_min
SDL_max
SDL_clamp
SDL_copyp
SDL_zero
SDL_zerop
SDL_zeroa
SDL_iconv_utf8_locale
SDL_iconv_utf8_ucs2
SDL_iconv_utf8_ucs4
SDL_iconv_wchar_utf8
SDL_size_add_check_overflow
SDL_memcpy
SDL_memmove
SDL_memset